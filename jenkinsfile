pipeline {
    agent any

    tools {
        nodejs 'Node18'
    }

    environment {
        CI = 'true'
    }

    parameters {
        string(name: 'TAG', defaultValue: '@smoke', description: 'Test tag')
    }

    stages {

        stage('Install Dependencies') {
            steps {
                sh 'npm ci'
                sh 'npx playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                sh "npx playwright test --grep ${TAG}"
            }
        }

        stage('Allure Report') {
            steps {
                allure includeProperties: false, jdk: '', results: [[path: 'allure-results']]
            }
        }
    }
}